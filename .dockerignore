# Only ignore local build outputs that shouldn't be in context:
client/dist/
core/ui/dist/
core/dist/

# Environment files
.env
.env.local
.env.*.local

# Git
.git/
.gitignore

# Docker
.dockerignore
docker-compose.yml
Dockerfile*

# IDE
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db

# Logs
*.log
